<Layouts.flash_group flash={@flash} />

<div class="min-h-screen bg-base-300 text-base-content relative overflow-hidden flex flex-col">
  <%!-- Background atmosphere --%>
  <div class="pointer-events-none absolute inset-0">
    <%!-- Dot grid --%>
    <svg class="absolute inset-0 w-full h-full opacity-[0.035]" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dots" width="32" height="32" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="0.75" fill="currentColor" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dots)" />
    </svg>

    <%!-- Gradient glows for depth --%>
    <div class="absolute top-[10%] left-[5%] w-[600px] h-[600px] rounded-full bg-primary/[0.04] blur-[120px]">
    </div>
    <div class="absolute bottom-[5%] right-[10%] w-[500px] h-[500px] rounded-full bg-info/[0.03] blur-[120px]">
    </div>

    <%!-- Top accent line --%>
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-primary/40 to-transparent">
    </div>
  </div>

  <%!-- Top navigation --%>
  <nav class="relative z-10 flex items-center justify-between px-6 sm:px-10 lg:px-16 py-6">
    <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-base-content/70">
      Playground
    </span>
    <div class="flex items-center gap-6">
      <%= if @current_scope && @current_scope.user do %>
        <span class="font-mono text-xs text-base-content/70 truncate max-w-[160px]">
          {@current_scope.user["email"]}
        </span>
        <a
          href="/sign-out"
          class="font-mono text-xs text-base-content/70 hover:text-error transition-colors duration-300"
        >
          Sign out
        </a>
      <% else %>
        <a
          href="/sign-in"
          class="font-mono text-xs text-base-content/70 hover:text-primary transition-colors duration-300"
        >
          Sign in <span class="text-primary/70">→</span>
        </a>
      <% end %>
    </div>
  </nav>

  <%!-- Beta banner --%>
  <div class="relative z-10 px-6 sm:px-10 lg:px-16" id="beta-banner">
    <a
      href="mailto:playground@sgiath.dev?subject=Beta%20access%20request"
      class={[
        "group relative flex items-center justify-between gap-4 px-5 py-3.5 rounded-lg overflow-hidden",
        "border border-secondary/25 bg-secondary/[0.08]",
        "shadow-md shadow-secondary/[0.06]",
        "transition-all duration-300",
        "hover:border-secondary/40 hover:bg-secondary/[0.12]",
        "hover:shadow-lg hover:shadow-secondary/[0.12]"
      ]}
    >
      <%!-- Glow accent --%>
      <div class="pointer-events-none absolute -left-10 -top-10 w-40 h-40 rounded-full bg-secondary/[0.08] blur-[60px]">
      </div>
      <div class="relative flex items-center gap-3 min-w-0">
        <span class="flex items-center gap-2 shrink-0">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-secondary opacity-60">
            </span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-secondary"></span>
          </span>
          <span class="font-mono text-[11px] tracking-[0.15em] uppercase text-secondary font-semibold">
            Beta
          </span>
        </span>
        <span class="hidden sm:inline h-3.5 w-px bg-secondary/20"></span>
        <span class="text-sm text-base-content/90 truncate">
          Closed beta — request an invite
        </span>
      </div>
      <span class="relative flex items-center gap-2 shrink-0">
        <.icon
          name="hero-envelope"
          class="w-3.5 h-3.5 text-secondary/60 group-hover:text-secondary transition-colors duration-300"
        />
        <span class="hidden sm:inline font-mono text-xs text-secondary/70 group-hover:text-secondary transition-colors duration-300">
          playground@sgiath.dev
        </span>
        <.icon
          name="hero-arrow-up-right"
          class="w-3 h-3 text-secondary/50 group-hover:text-secondary transition-all duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
        />
      </span>
    </a>
  </div>

  <%!-- Hero --%>
  <section class="relative z-10 flex-1 flex flex-col justify-center px-6 sm:px-10 lg:px-16 py-16 min-h-[70vh]">
    <div class="max-w-5xl">
      <%!-- Status indicator --%>
      <div class="home-reveal flex items-center gap-3 mb-14">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75">
          </span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-success"></span>
        </span>
        <span class="font-mono text-[11px] tracking-[0.15em] uppercase text-base-content/60">
          Online
        </span>
      </div>

      <%!-- Headline --%>
      <h1 class="home-reveal [animation-delay:0.1s] select-none">
        <span class="block text-[clamp(3.5rem,12vw,9rem)] font-black tracking-[-0.04em] leading-[0.85]">
          Play
        </span>
        <span class="block text-[clamp(3.5rem,12vw,9rem)] font-black tracking-[-0.04em] leading-[0.85] text-primary">
          ground<span class="home-cursor font-extralight text-base-content/50 ml-0.5">_</span>
        </span>
      </h1>

      <%!-- Tagline --%>
      <p class="home-reveal [animation-delay:0.2s] mt-10 max-w-md text-base sm:text-lg text-base-content/80 leading-relaxed">
        An experimental workspace for building, testing, and conversing with AI agents.
      </p>

      <%!-- Actions --%>
      <div class="home-reveal [animation-delay:0.3s] flex flex-wrap items-center gap-4 mt-12">
        <%= if @current_scope && @current_scope.user do %>
          <a
            href="/agent"
            class={[
              "group inline-flex items-center gap-2.5 px-7 py-3.5 rounded-lg",
              "bg-primary text-primary-content font-medium text-sm",
              "transition-all duration-300",
              "hover:shadow-lg hover:shadow-primary/25 hover:brightness-110"
            ]}
          >
            Open workspace
            <.icon
              name="hero-arrow-right"
              class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5"
            />
          </a>
          <a
            href="/conv"
            class={[
              "inline-flex items-center gap-2 px-6 py-3.5 rounded-lg",
              "text-sm font-medium text-base-content/80",
              "transition-all duration-300",
              "hover:text-base-content hover:bg-base-content/[0.08]"
            ]}
          >
            Conversations
          </a>
        <% else %>
          <a
            href="/sign-up"
            class={[
              "group inline-flex items-center gap-2.5 px-7 py-3.5 rounded-lg",
              "bg-primary text-primary-content font-medium text-sm",
              "transition-all duration-300",
              "hover:shadow-lg hover:shadow-primary/25 hover:brightness-110"
            ]}
          >
            Get started
            <.icon
              name="hero-arrow-right"
              class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5"
            />
          </a>
          <a
            href="/agent"
            class={[
              "inline-flex items-center gap-2 px-6 py-3.5 rounded-lg",
              "text-sm font-medium text-base-content/80",
              "transition-all duration-300",
              "hover:text-base-content hover:bg-base-content/[0.08]"
            ]}
          >
            Explore agents
          </a>
        <% end %>
      </div>
    </div>

    <%!-- Decorative vertical rule --%>
    <div class="hidden lg:block absolute right-16 top-1/2 -translate-y-1/2 h-40 w-px bg-gradient-to-b from-transparent via-base-content/[0.10] to-transparent">
    </div>
  </section>

  <%!-- Modules --%>
  <section class="relative z-10 px-6 sm:px-10 lg:px-16 pb-24">
    <%!-- Section divider --%>
    <div class="home-reveal [animation-delay:0.4s] flex items-center gap-5 mb-10">
      <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-base-content/60">
        Modules
      </span>
      <div class="flex-1 h-px bg-base-content/[0.12]"></div>
    </div>

    <%!-- Cards --%>
    <div class="home-reveal [animation-delay:0.5s] grid sm:grid-cols-2 gap-5 max-w-3xl">
      <%!-- Agents card --%>
      <a href="/agent" class="group block" id="home-agents-card">
        <div class={[
          "h-full p-7 rounded-xl",
          "border border-base-content/[0.12] bg-base-200/60",
          "transition-all duration-300",
          "hover:border-primary/30 hover:bg-base-200/80",
          "hover:shadow-xl hover:shadow-primary/[0.04]"
        ]}>
          <div class="flex items-start justify-between mb-8">
            <div class="p-2.5 rounded-lg bg-primary/10 ring-1 ring-primary/[0.08]">
              <.icon name="hero-cpu-chip" class="w-5 h-5 text-primary" />
            </div>
            <.icon
              name="hero-arrow-up-right"
              class="w-4 h-4 text-base-content/40 group-hover:text-primary/70 transition-colors duration-300"
            />
          </div>
          <h3 class="text-lg font-semibold mb-2.5 group-hover:text-primary transition-colors duration-300">
            Agents
          </h3>
          <p class="text-[13px] text-base-content/75 leading-relaxed">
            Configure and deploy autonomous AI agents with custom tools, system prompts,
            and model parameters.
          </p>
          <div class="mt-7 font-mono text-[11px] text-base-content/45 group-hover:text-primary/70 transition-colors duration-300">
            /agent
          </div>
        </div>
      </a>

      <%!-- Conversations card --%>
      <a href="/conv" class="group block" id="home-conv-card">
        <div class={[
          "h-full p-7 rounded-xl",
          "border border-base-content/[0.12] bg-base-200/60",
          "transition-all duration-300",
          "hover:border-info/30 hover:bg-base-200/80",
          "hover:shadow-xl hover:shadow-info/[0.04]"
        ]}>
          <div class="flex items-start justify-between mb-8">
            <div class="p-2.5 rounded-lg bg-info/10 ring-1 ring-info/[0.08]">
              <.icon name="hero-chat-bubble-left-right" class="w-5 h-5 text-info" />
            </div>
            <.icon
              name="hero-arrow-up-right"
              class="w-4 h-4 text-base-content/40 group-hover:text-info/70 transition-colors duration-300"
            />
          </div>
          <h3 class="text-lg font-semibold mb-2.5 group-hover:text-info transition-colors duration-300">
            Conversations
          </h3>
          <p class="text-[13px] text-base-content/75 leading-relaxed">
            Multi-turn conversations with streaming responses, rich markdown rendering,
            and full message history.
          </p>
          <div class="mt-7 font-mono text-[11px] text-base-content/45 group-hover:text-info/70 transition-colors duration-300">
            /conv
          </div>
        </div>
      </a>
    </div>
  </section>

  <%!-- Footer --%>
  <footer class="relative z-10 px-6 sm:px-10 lg:px-16 py-6 mt-auto">
    <div class="flex items-center justify-between border-t border-base-content/[0.12] pt-6">
      <span class="font-mono text-[10px] tracking-wider text-base-content/50">
        © {Date.utc_today().year}
      </span>
      <a
        href="https://sgiath.dev"
        target="_blank"
        rel="noopener"
        class="font-mono text-[10px] tracking-wider text-base-content/50 hover:text-base-content/80 transition-colors duration-300"
      >
        sgiath.dev
      </a>
    </div>
  </footer>
</div>
